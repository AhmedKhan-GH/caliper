# Build directories
build/
cmake-build-*/
out/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# ImGui
imgui.ini

# Data directories (comment out if you want to track data)
data/

# Third-party libraries
# Ignore generated/built files in third_party, but track custom CMakeLists.txt
third_party/*/build/
third_party/*/cmake-build-*/
third_party/libtorch/

# Ignore generated files in submodules
third_party/*/.dummy
third_party/OpenGL-Registry/extensions/

# But allow custom integration CMakeLists
!third_party/glew/CMakeLists.txt
!third_party/imgui/CMakeLists.txt
!third_party/implot/CMakeLists.txt

# Pre-built third-party libraries (legacy)
old_builds/
third_party/glew-prebuilt/

# macOS
.DS_Store
*.dSYM/

# Executables
caliper
*.exe
*.out
*.app

# Compiled files
*.o
*.a
*.so
*.dylib

# Python (if adding Python bindings later)
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
*.whl

dump
.swarm
.claude